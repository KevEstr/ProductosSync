# ============================================================
#  .env  — Configuración de producción (servidor remoto)
#  Renombrar este archivo a ".env" y ajustar los valores
# ============================================================

FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=cambia_esto_por_una_clave_aleatoria_segura

# ----------------------------------------------------------
#  API KEY - SEGURIDAD
#  Genera una clave aleatoria segura para proteger tu API
#  Ejemplo: mi_clave_secreta_123456
# ----------------------------------------------------------
API_KEY=tu_api_key_aqui

# ----------------------------------------------------------
#  RUTA A LOS DATOS DBF
#
#  DBF_PATH apunta directamente a la carpeta DbfRed
#  Ajusta esta ruta según donde esté ubicada tu carpeta
# ----------------------------------------------------------
DBF_PATH=../DbfRed

# Encoding de los archivos DBF de FoxPro
DBF_ENCODING=latin-1

# ----------------------------------------------------------
#  SINCRONIZACIÓN
#  Intervalo en minutos para actualizar el caché
# ----------------------------------------------------------
SYNC_INTERVAL_MINUTES=30

# ----------------------------------------------------------
#  SERVIDOR
# ----------------------------------------------------------
PORT=8090
HOST=0.0.0.0

# CORS: * permite cualquier origen. Para restringir:
#   ALLOWED_ORIGINS=http://192.168.1.50,http://192.168.1.51
ALLOWED_ORIGINS=*

# ----------------------------------------------------------
#  CACHÉ  (segundos)
#  3 horas = 10800 segundos
# ----------------------------------------------------------
CACHE_TIMEOUT=10800

# ----------------------------------------------------------
#  LOGGING
# ----------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
