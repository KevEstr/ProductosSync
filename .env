# ============================================================
#  .env  — Configuración de producción
# ============================================================

FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=productos-sync-secret-key-2025

# ----------------------------------------------------------
#  API KEY - SEGURIDAD
#  IMPORTANTE: Cambia esta clave por una segura
# ----------------------------------------------------------
API_KEY=mi_clave_secreta_123456

# ----------------------------------------------------------
#  RUTA A LOS DATOS DBF
#  Apunta a la carpeta DbfRed que está en el nivel superior
# ----------------------------------------------------------
DBF_PATH=../DbfRed

# Encoding de los archivos DBF de FoxPro
DBF_ENCODING=latin-1

# ----------------------------------------------------------
#  SINCRONIZACIÓN
#  Intervalo en minutos para actualizar el caché
# ----------------------------------------------------------
SYNC_INTERVAL_MINUTES=30

# ----------------------------------------------------------
#  SERVIDOR
# ----------------------------------------------------------
PORT=8090
HOST=0.0.0.0

# CORS: * permite cualquier origen
ALLOWED_ORIGINS=*

# ----------------------------------------------------------
#  CACHÉ  (segundos)
#  3 horas = 10800 segundos
# ----------------------------------------------------------
CACHE_TIMEOUT=10800

# ----------------------------------------------------------
#  LOGGING
# ----------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ----------------------------------------------------------
#  CLOUDFLARE R2 (Opcional - para exponer sin Port Forwarding)
#  Deja CLOUDFLARE_ENABLED=False si no lo usas
# ----------------------------------------------------------
CLOUDFLARE_ENABLED=True
CLOUDFLARE_ACCOUNT_ID=943c04326454b58e41ab9866885745cf
CLOUDFLARE_ACCESS_KEY_ID=52de49bc4fbb0b0c262bea26822e840c
CLOUDFLARE_SECRET_ACCESS_KEY=b61d410d544559cf08860e3a72dcee4ad20a4a053284e4a5d3726d99be751a06
CLOUDFLARE_BUCKET_NAME=prueba-perfumes
